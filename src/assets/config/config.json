{
  "production": false,
  "apiUrl": "http://redline.localhost/api/ui",
  "redlineUrl": "http://redline.localhost",
  "appName": "DataSpace Portal",
  "version": "1.0.0",
  "features": {
    "enableMockData": false,
    "enableAnalytics": false,
    "enableDebugMode": true,
    "enableDevMode": true
  },
  "upload": {
    "maxFileSize": 10485760,
    "allowedFileTypes": [
      "application/pdf",
      "application/msword",
      "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
      "image/jpeg",
      "image/jpg",
      "image/png"
    ]
  },
  "provisioning": {
    "pollIntervalMs": 2000,
    "maxWaitMs": 90000
  },
  "useCases": [
    {
      "id": "uc-certificate-management",
      "name": "certificate-management",
      "label": "Certificate Management",
      "description": "Manage your certificate sharing with partners"
    }
  ],
  "defaultServiceProviderId": 1,
  "participantIdentifierPrefix": "did:web:identityhub.edc-v.svc.cluster.local%3A7083:"
}
